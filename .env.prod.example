APP_NAME="Mama Witch"
APP_ENV=production
APP_KEY=  # Generate: php -r "echo 'base64:' . base64_encode(random_bytes(32));"
APP_DEBUG=false
APP_URL=https://mamawitch.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database — OVH MySQL Production
DB_CONNECTION=mysql
DB_HOST=xxxxx.mysql.db  # From OVH control panel
DB_PORT=3306
DB_DATABASE=xxxxx       # From OVH control panel
DB_USERNAME=xxxxx       # From OVH control panel
DB_PASSWORD=            # Strong password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Mail — OVH SMTP
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=ssl0.ovh.net
MAIL_PORT=465
MAIL_USERNAME=noreply@mamawitch.fr
MAIL_PASSWORD=          # OVH email password
MAIL_FROM_ADDRESS="noreply@mamawitch.fr"
MAIL_FROM_NAME="Mama Witch"

VITE_APP_NAME="Mama Witch"

# Google OAuth
GOOGLE_CLIENT_ID=       # From Google Cloud Console
GOOGLE_CLIENT_SECRET=   # From Google Cloud Console
GOOGLE_REDIRECT_URI=https://mamawitch.fr/auth/google/callback

# Deploy token — Generate: openssl rand -hex 32
DEPLOY_TOKEN=
